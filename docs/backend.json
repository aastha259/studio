{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Bhartiya Swad platform, including both customers and administrators.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalMoneySpent": { "type": "number" },
        "address": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "email", "displayName", "role", "totalOrders", "totalMoneySpent"]
    },
    "Restaurant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Restaurant",
      "type": "object",
      "description": "Represents a restaurant partnered with the Bhartiya Swad platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "imageURL": { "type": "string", "format": "uri" },
        "averageRating": { "type": "number" },
        "totalOrders": { "type": "number" },
        "totalRevenue": { "type": "number" }
      },
      "required": ["id", "name", "address", "phone", "email", "imageURL", "averageRating", "totalOrders", "totalRevenue"]
    },
    "Dish": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Dish",
      "type": "object",
      "description": "Represents a single food item that can be ordered.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "rating": { "type": "number" },
        "category": { "type": "string", "enum": ["Starters", "Main Course - Veg", "Main Course - Non-Veg", "Breads", "Rice & Biryani", "Street Food", "Desserts", "Beverages"] },
        "isVeg": { "type": "boolean" },
        "restaurantId": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalRevenue": { "type": "number" }
      },
      "required": ["id", "name", "description", "price", "image", "rating", "category", "isVeg", "totalOrders", "totalRevenue"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Stores user profiles." }
      },
      {
        "path": "/dishes/{dishId}",
        "definition": { "entityName": "Dish", "description": "Stores individual authentic Indian dishes." }
      }
    ]
  }
}
