
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common security checks
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == 'xyz@admin.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // DISHES: Publicly viewable menu items.
    match /dishes/{dishId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles: Owners can manage their data, admins can see all
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // User's Cart: Only the owner can manage their cart
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ORDERS: Users can create and read their own orders. Admins manage all.
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Admin Roles: Strictly restricted to system administrators
    match /admin_roles/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    // Restaurants & Categories (Legacy or placeholder support)
    match /restaurants/{rId} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{cId} { allow read: if true; allow write: if isAdmin(); }
  }
}
